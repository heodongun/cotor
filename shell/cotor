#!/bin/bash
# Cotor CLI wrapper script

export PATH="${PATH:+$PATH:}$HOME/.local/bin:$HOME/.opencode/bin:$HOME/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"

# Get the real path of this script (follow symlinks)
SCRIPT_PATH="$(/usr/bin/python3 -c 'import os, sys; print(os.path.realpath(sys.argv[1]))' "$0" 2>/dev/null || echo "$0")"
SCRIPT_DIR="$(cd "$(/usr/bin/dirname "$SCRIPT_PATH")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Find JDK 17 for Gradle builds and JAR execution.
# The project targets JDK 17 (build.gradle.kts jvmToolchain(17)).
if [ -z "$JAVA_HOME" ] || ! "$JAVA_HOME/bin/java" -version 2>&1 | /usr/bin/grep -q '"17\.'; then
    for candidate in \
        "$HOME/Library/Java/JavaVirtualMachines/corretto-17"*/Contents/Home \
        "$HOME/Library/Java/JavaVirtualMachines/temurin-17"*/Contents/Home \
        "$HOME/Library/Java/JavaVirtualMachines/ms-17"*/Contents/Home \
        /Library/Java/JavaVirtualMachines/jdk-17*/Contents/Home \
        /Library/Java/JavaVirtualMachines/temurin-17*/Contents/Home \
        /Library/Java/JavaVirtualMachines/corretto-17*/Contents/Home \
        /Library/Java/JavaVirtualMachines/amazon-corretto-17*/Contents/Home; do
        if [ -x "$candidate/bin/java" ]; then
            export JAVA_HOME="$candidate"
            break
        fi
    done
fi

if [ -z "$JAVA_HOME" ]; then
    JDK17=$(/usr/libexec/java_home -v 17 2>/dev/null || true)
    if [ -n "$JDK17" ] && [ -x "$JDK17/bin/java" ]; then
        export JAVA_HOME="$JDK17"
    fi
fi

if ! command -v java &> /dev/null && [ -z "$JAVA_HOME" ]; then
    echo "Error: Java 17 is not installed or not in PATH"
    echo "Please install JDK 17: brew install --cask corretto@17"
    exit 1
fi

JAVA_CMD="${JAVA_HOME:+$JAVA_HOME/bin/}java"

# Determine project version from build.gradle.kts and fall back to the newest shaded jar.
APP_VERSION=$(/usr/bin/grep -E '^[[:space:]]*version[[:space:]]*=' "$PROJECT_ROOT/build.gradle.kts" | /usr/bin/head -n 1 | /usr/bin/cut -d '"' -f2 | /usr/bin/tr -d '\r')
[ -z "$APP_VERSION" ] && APP_VERSION="1.0.0"

# Path to the shaded JAR file (built via shadowJar)
JAR_PATH="$PROJECT_ROOT/build/libs/cotor-${APP_VERSION}-all.jar"

# Build the CLI if the shaded JAR is missing
if [ ! -f "$JAR_PATH" ]; then
    echo "Building cotor CLI (./gradlew shadowJar)..."
    if [ -x "$PROJECT_ROOT/gradlew" ]; then
        (cd "$PROJECT_ROOT" && ./gradlew shadowJar) || exit 1
    else
        echo "Error: gradlew not found in $PROJECT_ROOT"
        exit 1
    fi
fi

if [ ! -f "$JAR_PATH" ]; then
    LATEST_JAR=$(/bin/ls -1t "$PROJECT_ROOT"/build/libs/cotor-*-all.jar 2>/dev/null | /usr/bin/head -n 1)
    if [ -n "$LATEST_JAR" ] && [ -f "$LATEST_JAR" ]; then
        JAR_PATH="$LATEST_JAR"
    else
        echo "Error: unable to locate shaded CLI jar under $PROJECT_ROOT/build/libs"
        exit 1
    fi
fi

if [ "${1:-}" = "app-server" ]; then
    APP_HOME="${COTOR_APP_HOME:-${HOME}/Library/Application Support/CotorDesktop}"
    RUNTIME_BACKEND_DIR="$APP_HOME/runtime/backend"
    RUNTIME_JAR="$RUNTIME_BACKEND_DIR/cotor-app-server-$$.jar"
    /bin/mkdir -p "$RUNTIME_BACKEND_DIR" || exit 1
    /bin/cp "$JAR_PATH" "$RUNTIME_JAR" || exit 1
    cleanup_runtime_jar() {
        /bin/rm -f "$RUNTIME_JAR" >/dev/null 2>&1 || true
    }
    trap cleanup_runtime_jar EXIT
    JAR_PATH="$RUNTIME_JAR"
fi

# Run the JAR with all arguments passed to this script
export COTOR_PROJECT_ROOT="$PROJECT_ROOT"
"$JAVA_CMD" -jar "$JAR_PATH" "$@"
